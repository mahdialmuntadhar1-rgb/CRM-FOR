{
  "version": 2,
  "builds": [
    {
      "src": "whatsapp-crm/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/whatsapp-crm/index.html"
    }
  ],
  "installCommand": "cd whatsapp-crm && npm install",
  "buildCommand": "cd whatsapp-crm && npm run build",
  "outputDirectory": "whatsapp-crm/dist",
  "env": {
    "NODE_ENV": "production"
  }
}
