# =====================================================
# WhatsApp CRM - Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to git!
# =====================================================

# -----------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------
# Frontend/Client (safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend ONLY (NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------
# NABDA WHATSAPP API
# -----------------------------------------------------
NABDA_API_URL=https://api.nabdaotp.com
NABDA_INSTANCE_ID=your_instance_id
NABDA_API_TOKEN=your_api_token

# -----------------------------------------------------
# API SERVER CONFIG
# -----------------------------------------------------
API_PORT=3001
NODE_ENV=development
JWT_SECRET=your-jwt-secret-for-api-auth

# -----------------------------------------------------
# CAMPAIGN DEFAULTS (can be overridden per campaign)
# -----------------------------------------------------
DEFAULT_DAILY_LIMIT=50
DEFAULT_MIN_DELAY_SECONDS=45
DEFAULT_MAX_DELAY_SECONDS=120
DEFAULT_BATCH_SIZE=5
MAX_RETRY_ATTEMPTS=3

# -----------------------------------------------------
# SECURITY & COMPLIANCE
# -----------------------------------------------------
# Comma-separated list of test numbers (will be allowed in test mode)
TEST_PHONE_NUMBERS=+9647700000000,+9647800000000
# Webhook signature secret (if Nabda supports it)
WEBHOOK_SECRET=your-webhook-secret

# -----------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------
ENABLE_TEST_MODE=true
ENABLE_AUTO_FOLLOWUP=true
ENABLE_INTENT_DETECTION=true
